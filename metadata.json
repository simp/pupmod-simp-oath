{
  "name": "simp-oath",
  "version": "1.0.0",
  "author": "https://github.com/simp/pupmod-simp-oath/graphs/contributors",
  "summary": "Installation and config for pam_oath rpm",
  "license": "Apache-2.0",
  "source": "https://github.com/simp/pupmod-simp-oath.git",
  "project_page": "https://github.com/simp/pupmod-simp-oath",
  "issues_url": "https://github.com/simp/pupmod-simp-oath/issues",
  "tags": [
    "simp",
    "oath",
    "totp"
  ],
  "dependencies": [
    {
      "name": "puppetlabs/concat",
      "version_requirement": ">= 6.4.0 < 10.0.0"
    },
    {
